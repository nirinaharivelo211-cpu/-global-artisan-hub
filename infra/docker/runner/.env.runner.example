# ============================================================
# TISSAGE — GitLab Runner Configuration
# ============================================================
# Copier vers .env.runner et remplir les valeurs
# ============================================================

# URL du GitLab CE
GITLAB_URL=http://192.168.10.62:8080

# Token d'enregistrement (Settings > CI/CD > Runners)
REGISTRATION_TOKEN=

# Nom du runner
RUNNER_NAME=tissage-runner

# Tags associés (séparés par des virgules)
RUNNER_TAG_LIST=dev,staging,production,monitoring

# Concurrence maximale de jobs
RUNNER_CONCURRENT=4
