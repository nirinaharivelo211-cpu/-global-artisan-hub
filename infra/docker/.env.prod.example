# =============================================================
# TISSAGE — Production Environment
# Copy this file as .env and fill in your values
# =============================================================

# --- Flask / Backend ---
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-secret-key
JWT_SECRET_KEY=change-me-to-another-random-key
FRONTEND_URL=https://artisanmada.com
CORS_ORIGINS=https://artisanmada.com

# --- PostgreSQL ---
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Stripe (card payments in EUR) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# --- Flutterwave (mobile money in MGA) ---
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_ENCRYPTION_KEY=
FLW_WEBHOOK_SECRET=

# --- Celery / Redis (already configured in compose) ---
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Email (SMTP) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Supabase (frontend auth) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# --- Mobile Money Madagascar ---
MM_MVOLA_NUMBER=034 12 345 67
MM_AIRTEL_NUMBER=032 12 345 67
MM_ORANGE_NUMBER=033 12 345 67
